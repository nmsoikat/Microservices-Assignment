                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{base_url}}/auth/refresh-token",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "auth",
                    "refresh-token"
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Logout",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const response = pm.response.json();",
                      "if (response.success) {",
                      "    pm.environment.set(\"access_token\", 'empty');",
                      "    pm.environment.set(\"refresh_token\", 'empty');",
                      "}"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
